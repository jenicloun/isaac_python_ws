from launch import LaunchDescription
from launch.actions import DeclareLaunchArgument, GroupAction, TimerAction
from launch.substitutions import LaunchConfiguration, PathJoinSubstitution
from launch_ros.actions import Node
from launch_ros.substitutions import FindPackageShare


def generate_launch_description():
    map_file_arg = DeclareLaunchArgument(
        name="map",
        default_value="carter_warehouse_navigation.yaml",
        description="YAML map file name",
    )
    use_sim_time_arg = DeclareLaunchArgument(
        name="use_sim_time",
        default_value="true",
        description="Use simulation clock if true",
    )
    autostart_arg = DeclareLaunchArgument(
        name="autostart",
        default_value="true",
        description="Automatically startup the nav2 stack",
    )

    map_file = PathJoinSubstitution([
        FindPackageShare("isaac_mapf"),
        "config",
        LaunchConfiguration("map"),
    ])

    use_sim_time = LaunchConfiguration("use_sim_time")
    autostart = LaunchConfiguration("autostart")

    lifecycle_nodes = ["map_server", "mapf_base_node"]

    mapf_params = PathJoinSubstitution([
        FindPackageShare("isaac_mapf"),
        "config",
        "mapf_params_3g.yaml",
    ])

    costmap_params = PathJoinSubstitution([
        FindPackageShare("isaac_mapf"),
        "config",
        "costmap_params.yaml",
    ])

    return LaunchDescription([
        map_file_arg,
        use_sim_time_arg,
        autostart_arg,

        Node(
            package='isaac_mapf',
            executable='tf_prefix_relay',
            name='carter1_tf_relay',
            output='screen',
            parameters=[
                {'input_tf_topic': '/carter1/tf'},
                {'output_tf_topic': '/tf'},
                {'prefix': 'carter1'},
                {'global_frames': ['World']},
            ]
        ),

        # Node(
        #     package='isaac_mapf',
        #     executable='goal_pose_publisher',
        #     name='carter1_goal_publisher',
        #     output='screen',
        #     parameters=[
        #         {'frame_id': 'World'},
        #         {'x': 0.0},
        #         {'y': 3.0},
        #         {'yaw': 0.0},
        #         {'period': 1.0},
        #     ]
        # ),
        
        Node(
            package='isaac_mapf',
            executable='plan_to_cmdvel',
            name='carter1_plan_to_cmdvel',
            output='screen',
            parameters=[
                {'plan_topic': '/mapf/carter1/plan'},
                {'cmd_vel_topic': '/carter1/cmd_vel'},
                {'global_frame': 'map'},
                {'base_frame': 'carter1/chassis_link/base_link'},
                {'control_rate': 10.0},
                {'lookahead_index': 3},
                {'goal_tolerance': 0.15},
                {'linear_k': 3.0},
                {'angular_k': 0.8},
                {'max_linear': 5.0},
                {'max_angular': 0.6},
            ]
        ),

        Node(
            package='isaac_mapf',
            executable='tf_prefix_relay',
            name='carter2_tf_relay',
            output='screen',
            parameters=[
                {'input_tf_topic': '/carter2/tf'},
                {'output_tf_topic': '/tf'},
                {'prefix': 'carter2'},
                {'global_frames': ['World']},
            ]
        ),

        # Node(
        #     package='isaac_mapf',
        #     executable='goal_pose_publisher',
        #     name='carter2_goal_publisher',
        #     output='screen',
        #     parameters=[
        #         {'topic_name': '/carter2/goal'},
        #         {'frame_id': 'World'},
        #         {'x': 0.0},
        #         {'y': 3.0},
        #         {'yaw': 0.0},
        #         {'period': 1.0},
        #     ]
        # ),
        
        Node(
            package='isaac_mapf',
            executable='plan_to_cmdvel',
            name='carter2_plan_to_cmdvel',
            output='screen',
            parameters=[
                {'plan_topic': '/mapf/carter2/plan'},
                {'cmd_vel_topic': '/carter2/cmd_vel'},
                {'global_frame': 'map'},
                {'base_frame': 'carter2/chassis_link/base_link'},
                {'control_rate': 10.0},
                {'lookahead_index': 3},
                {'goal_tolerance': 0.15},
                {'linear_k': 3.0},
                {'angular_k': 0.8},
                {'max_linear': 5.0},
                {'max_angular': 0.6},
            ]
        ),
        
        Node(
            package='isaac_mapf',
            executable='tf_prefix_relay',
            name='carter3_tf_relay',
            output='screen',
            parameters=[
                {'input_tf_topic': '/carter3/tf'},
                {'output_tf_topic': '/tf'},
                {'prefix': 'carter3'},
                {'global_frames': ['World']},
            ]
        ),

        # Node(
        #     package='isaac_mapf',
        #     executable='goal_pose_publisher',
        #     name='carter3_goal_publisher',
        #     output='screen',
        #     parameters=[
        #         {'topic_name': '/carter3/goal'},
        #         {'frame_id': 'World'},
        #         {'x': 0.0},
        #         {'y': 3.0},
        #         {'yaw': 0.0},
        #         {'period': 1.0},
        #     ]
        # ),
        
        Node(
            package='isaac_mapf',
            executable='plan_to_cmdvel',
            name='carter3_plan_to_cmdvel',
            output='screen',
            parameters=[
                {'plan_topic': '/mapf/carter3/plan'},
                {'cmd_vel_topic': '/carter3/cmd_vel'},
                {'global_frame': 'map'},
                {'base_frame': 'carter3/chassis_link/base_link'},
                {'control_rate': 10.0},
                {'lookahead_index': 3},
                {'goal_tolerance': 0.15},
                {'linear_k': 3.0},
                {'angular_k': 0.8},
                {'max_linear': 5.0},
                {'max_angular': 0.6},
            ]
        ),
        
        GroupAction([
            Node(
                namespace="mapf",
                package="nav2_map_server",
                executable="map_server",
                name="map_server",
                output="screen",
                respawn=True,
                parameters=[
                    mapf_params,
                    {"yaml_filename": map_file},
                ],
            ),
            Node(
                namespace="mapf",
                package="mapf_base",
                executable="mapf_base_node",
                name="mapf_base_node",
                output="screen",
                respawn=True,
                parameters=[
                    costmap_params,
                    mapf_params,
                ],
            ),
            Node(
                namespace="mapf",
                package="nav2_lifecycle_manager",
                executable="lifecycle_manager",
                name="lifecycle_manager_mapf",
                output="screen",
                parameters=[
                    {"use_sim_time": use_sim_time},
                    {"autostart": autostart},
                    {"node_names": lifecycle_nodes},
                ],
            ),
        ]),

        TimerAction(
            period=2.0,
            actions=[
                GroupAction([
                    Node(
                        namespace="mapf",
                        package="mapf_base",
                        executable="goal_transformer",
                        name="goal_transformer",
                        output="screen",
                        parameters=[mapf_params],
                    ),
                ])
            ],
        ),
    ])